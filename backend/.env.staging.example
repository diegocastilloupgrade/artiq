# Staging environment configuration
# Copy to .env and adjust values for your staging infrastructure

NODE_ENV=staging
PORT=3000

# Database
DATABASE_HOST=postgres.staging.internal
DATABASE_PORT=5432
DATABASE_USER=artiq_staging_user
DATABASE_PASSWORD=your-strong-staging-password
DATABASE_NAME=artiq_staging

# JWT - Use a strong random value
JWT_SECRET=your-strong-jwt-secret-for-staging-change-it
JWT_EXPIRATION=7d

# Amazon Affiliate
AMAZON_AFFILIATE_ACCESS_KEY=your-staging-amazon-access-key
AMAZON_AFFILIATE_SECRET_KEY=your-staging-amazon-secret-key
AMAZON_AFFILIATE_TAG=your-staging-affiliate-tag

# CMS
CMS_PROVIDER=wordpress
CMS_URL=https://staging-cms.yourcompany.com
CMS_API_KEY=your-staging-cms-api-key

# Analytics
GA4_PROPERTY_ID=G-XXXXXXXXXX
GTM_CONTAINER_ID=GTM-XXXXXX

# AI
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-staging-openai-key

# Trend Sources
GOOGLE_TRENDS_REGION=US

# Redis
REDIS_HOST=redis.staging.internal
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
