# Environment
NODE_ENV=development
PORT=3000

# Database Configuration
# For development, defaults are provided
# For staging/production, all are required
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=artiq_user
DATABASE_PASSWORD=artiq_password
DATABASE_NAME=artiq_db

# JWT & Authentication
# In production, JWT_SECRET MUST be a strong random string
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production-12345
JWT_EXPIRATION=7d

# Amazon Affiliate Configuration
AMAZON_AFFILIATE_ACCESS_KEY=your-amazon-access-key
AMAZON_AFFILIATE_SECRET_KEY=your-amazon-secret-key
AMAZON_AFFILIATE_TAG=your-affiliate-tag-20

# CMS Integration
# Supported providers: wordpress, strapi, custom
CMS_PROVIDER=wordpress
CMS_URL=https://your-cms-domain.com
CMS_API_KEY=your-cms-api-key

# Google Analytics & GTM
GA4_PROPERTY_ID=G-XXXXXXXXXX
GTM_CONTAINER_ID=GTM-XXXXXX

# AI Generation Provider
# Supported: openai, anthropic, other
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key

# Trend Sources
GOOGLE_TRENDS_REGION=US

# Redis (optional, for caching/queues)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
