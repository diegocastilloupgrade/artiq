# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=artiq_user
DATABASE_PASSWORD=artiq_password
DATABASE_NAME=artiq_db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=7d

# External services
AMAZON_AFFILIATE_ACCESS_KEY=your-amazon-access-key
AMAZON_AFFILIATE_SECRET_KEY=your-amazon-secret-key
AMAZON_AFFILIATE_TAG=your-affiliate-tag

# CMS Integration
CMS_PROVIDER=wordpress
CMS_URL=https://your-cms-domain.com
CMS_API_KEY=your-cms-api-key

# Analytics
GA4_PROPERTY_ID=your-ga4-property-id
GTM_CONTAINER_ID=your-gtm-container-id

# AI Generation
AI_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key

# Trend Sources
GOOGLE_TRENDS_REGION=US

# Environment
NODE_ENV=development
PORT=3000
